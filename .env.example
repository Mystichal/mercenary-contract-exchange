# ── Mercenary Contract Exchange — Environment Variables ──────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Verifier ──────────────────────────────────────────────────────────────────
# Private key for the wallet holding the VerifierCap object.
# Accepts bech32 (suiprivkey1...) or base64 format.
VERIFIER_PRIVATE_KEY=

# ── Frontend (Next.js public vars) ───────────────────────────────────────────
# These are exposed to the browser — do not put secrets here.
# See also: frontend/.env.local.example

# Deployed MCE package ID
NEXT_PUBLIC_PACKAGE_ID=0x769f425fddcdefa4877532aa773b23f4abcbd9f1abbd09183e8a972da609c781

# Shared Registry object ID
NEXT_PUBLIC_REGISTRY_ID=0x5bfe76bddf93f27668e999863ff9f10d2cbc69b1d7881c3305bbc407a23e087b

# EVE Frontier world-contracts package ID (for event polling)
NEXT_PUBLIC_WORLD_PKG=0x07e6b810c2dff6df56ea7fbad9ff32f4d84cbee53e496267515887b712924bd1

# Sui Clock object ID (always 0x6)
NEXT_PUBLIC_CLOCK_ID=0x6

# Sui network to connect to (testnet | mainnet | devnet | localnet)
NEXT_PUBLIC_NETWORK=testnet
